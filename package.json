    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fontsource/silkscreen": "^5.2.8",
    "@fontsource/vt323": "^5.2.7",
    "@vercel/analytics": "^2.0.1"
